{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "regex"
  ],
  "schedule": [
    "before 5am on monday"
  ],
  "regexManagers": [
    {
      "fileMatch": [
        "^versions\\.env$"
      ],
      "matchStrings": [
        "SONARQUBE_IMAGE_TAG=\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "sonarqube",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    },
    {
      "fileMatch": [
        "^versions\\.env$"
      ],
      "matchStrings": [
        "POSTGRES_IMAGE_TAG=\"(?<currentValue>[^\"]+)\""
      ],
      "depNameTemplate": "postgres",
      "datasourceTemplate": "docker",
      "versioningTemplate": "docker"
    }
  ],
  "packageRules": [
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "sonarqube"
      ],
      "allowedVersions": "/-community$/"
    },
    {
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "postgres"
      ],
      "allowedVersions": "/^17(?:\\.[0-9]+)?-alpine$/"
    }
  ]
}
